# ============================================================
# .env.example — Plantilla de variables de entorno (Backend)
# ============================================================
# Cómo usar:
#   1. Copiar este archivo:        cp .env.example .env
#   2. Editar .env con valores reales
#   3. NUNCA hacer commit del .env (ya está en .gitignore)
# ============================================================


# ─── Aplicación Node.js ─────────────────────────────────────
# Puerto donde escucha el servidor Express
PORT=3000


# ─── Conexión del Backend a MySQL ───────────────────────────
# Si corres LOCAL (fuera de Docker):       DB_HOST=localhost
# Si corres CON docker compose:            DB_HOST=database
# (el nombre del servicio MySQL en compose)
DB_HOST=database
DB_USER=app_user
DB_PASSWORD=CAMBIAR_EN_LOCAL
DB_NAME=proyecto_db
DB_PORT=3306


# ─── Credenciales que docker-compose pasa al contenedor MySQL ──
# Estas variables las lee docker-compose.yml para inicializar
# el contenedor de MySQL la primera vez que arranca.
# ⚠️ En producción (EC2) estas vienen de GitHub Secrets, NO de este archivo.
MYSQL_ROOT_PASSWORD=CAMBIAR_EN_LOCAL
MYSQL_DATABASE=proyecto_db
MYSQL_USER=app_user
MYSQL_PASSWORD=CAMBIAR_EN_LOCAL


# ─── Docker Hub (para CI/CD y producción) ───────────────────
# Tu usuario de Docker Hub donde se publica la imagen
DOCKERHUB_USERNAME=tu_usuario_dockerhub
# Tag de la imagen a usar (latest = última versión)
IMAGE_TAG=latest
