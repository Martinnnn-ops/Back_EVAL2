# ============================================================
# .gitignore — archivos que Git NO debe rastrear ni subir
# ============================================================


# ─── Dependencias de Node ───────────────────────────────────
# Se reinstalan con "npm install" — no se suben al repo
node_modules/
jspm_packages/


# ─── Variables de entorno (¡SECRETOS!) ──────────────────────
# Contienen contraseñas reales — NUNCA subir
.env
.env.local
.env.*.local
.env.production
# Excepción: el .env.example SÍ debe ir al repo (es la plantilla)


# ─── Logs ───────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log
logs/


# ─── Coverage / tests ───────────────────────────────────────
coverage/
.nyc_output/
*.lcov


# ─── Editor / IDE ───────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~


# ─── Sistema operativo ──────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini


# ─── Compilados / build ─────────────────────────────────────
dist/
build/
*.tgz


# ─── Caché ──────────────────────────────────────────────────
.npm
.eslintcache
.cache/
